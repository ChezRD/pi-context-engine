{
  "name": "pi-context-engine",
  "version": "0.2.3",
  "description": "Unified Pi context management: prompt-cache telemetry, semantic folding, pruning, checkpoints, and visualization",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "cache",
    "prompt-cache",
    "context-prune",
    "context-management",
    "checkpoint",
    "semantic-fold"
  ],
  "license": "MIT",
  "files": [
    "src/**/*.ts",
    "src/**/*.json",
    "README.md",
    "THIRD_PARTY_NOTICES.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "i18n:audit": "node scripts/audit-locales.mjs",
    "i18n:sort": "node scripts/sort-locales.mjs",
    "test": "node --test tests/**/*.test.mjs",
    "typecheck": "npm run typecheck:project",
    "typecheck:project": "tsc -p tsconfig.json --noEmit --pretty false"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*",
    "@juicesharp/rpiv-i18n": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "0.75.5",
    "typebox": "1.1.38",
    "typescript": "5.9.3",
    "@juicesharp/rpiv-i18n": "1.12.0"
  },
  "peerDependenciesMeta": {
    "@juicesharp/rpiv-i18n": {
      "optional": true
    }
  }
}
